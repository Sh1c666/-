# ===========================================================================
# NetPilot configuration. Copy this file to ".env" and fill in your values.
#   cp .env.example .env
# Every variable here can also be set as a real environment variable, or
# changed at runtime from the UI (Settings panel) — the UI overrides .env.
# ===========================================================================

# ---- LLM (any OpenAI-compatible endpoint) ----------------------------------
# NetPilot talks to any provider that exposes an OpenAI-compatible
# /chat/completions endpoint via the official `openai` SDK. Pick one below and
# fill in NETPILOT_LLM_API_KEY.
#
#   DeepSeek  (default):  BASE_URL=https://api.deepseek.com          MODEL=deepseek-chat
#   OpenAI:               BASE_URL=https://api.openai.com/v1         MODEL=gpt-4o-mini
#   GLM (智谱):            BASE_URL=https://open.bigmodel.cn/api/paas/v4/  MODEL=glm-4.5
#   Ollama (local):       BASE_URL=http://localhost:11434/v1         MODEL=qwen2.5   (key: any string)
#
# IMPORTANT: the model MUST support function/tool calling.
#   ✅ deepseek-chat, gpt-4o-mini, glm-4.5   ❌ deepseek-reasoner (R1) — no tool calling
NETPILOT_LLM_API_KEY=your-api-key-here

NETPILOT_LLM_BASE_URL=https://api.deepseek.com
NETPILOT_LLM_MODEL=deepseek-chat
# API protocol: "openai" (default, any /chat/completions endpoint) or "anthropic"
# (Anthropic Messages API). Use "anthropic" + BASE_URL=https://open.bigmodel.cn/api/anthropic
# when your BigModel plan only covers the Claude-compatible endpoint.
NETPILOT_LLM_PROTOCOL=openai

# Decoding
NETPILOT_LLM_TEMPERATURE=0.2
NETPILOT_LLM_MAX_TOKENS=2048

# Safety: hard cap on how many tool-calls the agent may make in one run.
NETPILOT_AGENT_MAX_STEPS=12

# ---- Privacy --------------------------------------------------------------
# Mask private/internal IPs before sending context to the cloud LLM.
# true = recommended for enterprise networks. The unmasked values stay local.
NETPILOT_PRIVACY_MASK_INTERNAL_IPS=true

# ---- Server ---------------------------------------------------------------
NETPILOT_HOST=127.0.0.1
NETPILOT_PORT=8000
NETPILOT_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local data directory (profiles, sessions). Relative to backend/.
NETPILOT_DATA_DIR=./data
